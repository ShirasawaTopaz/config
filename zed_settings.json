// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "cli_default_open_behavior": "existing_window",
    "project_panel": {
        "dock": "right",
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "right",
    },
    "git_panel": {
        "dock": "right",
        "tree_view": true,
    },
    "language_models": {
        "openai_compatible": {},
    },
    "ssh_connections": [],
    "agent_servers": {
        "codex-acp": {
            "type": "custom",
            "command": "C:\\Users\\34898\\AppData\\Roaming\\npm\\node_modules\\@zed-industries\\codex-acp\\node_modules\\@zed-industries\\codex-acp-win32-x64\\bin\\codex-acp.exe",
        },
        "claude-acp": {
            "type": "registry",
            "env": {
                "CLAUDE_CODE_EXECUTABLE": "C:\\Users\\34898\\AppData\\Roaming\\npm\\node_modules\\@anthropic-ai\\claude-code\\bin\\claude.exe",
            },
        },
        "OpenCode": {
            "type": "custom",
            "command": "opencode",
            "args": ["acp"],
        },
    },
    "buffer_font_family": "JetBrains Mono",
    "buffer_font_features": {
        "ss01": true,
    },
    "agent": {
        "dock": "left",
        "default_profile": "write",
        "default_model": {
            "enable_thinking": true,
            "provider": "ollama",
            "model": "gemma4:e2b",
        },
        "model_parameters": [],
    },
    "edit_predictions": {
        "provider": "zed",
        "disabled_globs": [],
    },
    "inlay_hints": {
        "enabled": true,
    },
    "auto_update": true,
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "vim_mode": true,
    "base_keymap": "VSCode",
    "minimap": {
        "show": "never",
    },
    "tab_size": 4,
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "file_types": {},
    "use_on_type_format": true,
    "show_edit_predictions": true,
    "ui_font_size": 16,
    "buffer_font_size": 17.0,
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "One Dark",
    },
    "languages": {
        "Java": {
            "inlay_hints": {
                "enabled": true,
            },
            "completions": {
                "words_min_length": 1,
            },
        },
        "JavaScript": {
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
            "formatter": [],
        },
        "TypeScript": {
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
            "formatter": [],
        },
        "Vue.js": {
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
            "formatter": [],
        },
    },
}
